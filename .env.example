# Copy to .env.local and fill in your Supabase project (Dashboard → Settings → API).

# Used by Vite when you add code that reads import.meta.env.VITE_*
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Optional: same values if you use Next.js or tooling that expects NEXT_PUBLIC_*
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
